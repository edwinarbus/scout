{
  "name": "scout",
  "version": "0.1.0",
  "private": true,
  "description": "Scout — a personal, non-commercial California dog adoption scout. Monitors CA shelter/rescue listings, normalizes them, and shows them on a map.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src scripts tests",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx scripts/seed.ts",
    "verify": "tsx scripts/verify.ts",
    "verify:live": "tsx scripts/verify.ts --live --enabled",
    "backfill": "tsx scripts/backfill.ts",
    "ingest": "tsx scripts/ingest.ts",
    "ingest:all": "tsx scripts/ingest.ts --all",
    "enrich": "tsx scripts/enrich.ts",
    "refresh": "tsx scripts/refresh.ts",
    "scout:vapid": "tsx scripts/vapid.ts",
    "scout:overnight": "tsx scripts/overnight.ts",
    "scout:setup-overnight-agent": "tsx scripts/setup-overnight-agent.ts",
    "scout:resume-overnight-agent": "tsx scripts/resume-deployment.ts",
    "scout:setup-watch-curator": "tsx scripts/setup-watch-curator.ts",
    "scout:prune-photos": "tsx scripts/prune-photos.ts",
    "scout:migrate-to-turso": "tsx scripts/migrate-to-turso.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "@libsql/client": "^0.17.4",
    "@types/web-push": "^3.6.4",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "maplibre-gl": "^5.24.0",
    "next": "^15.5.20",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
